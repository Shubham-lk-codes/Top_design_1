# Vercel Environment Variables
# Add these in Vercel Dashboard → Project Settings → Environment Variables

# Application
NODE_ENV=production
DOMAIN=www.topdesign.co.in

# Email (for contact form)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=info@topdesign.co.in

# Analytics (optional)
GOOGLE_ANALYTICS_ID=
FACEBOOK_PIXEL_ID=

# reCAPTCHA (optional)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
