# TOP DESIGN - Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=3000

# Domain
DOMAIN=www.topdesign.co.in
ALLOWED_ORIGINS=http://localhost:3000,https://www.topdesign.co.in

# Email Configuration (for contact form notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@topdesign.co.in
ADMIN_EMAIL=info@topdesign.co.in

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$YourHashedPasswordHere
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database (for production - MongoDB/MySQL/PostgreSQL)
# DATABASE_URL=mongodb://localhost:27017/topdesign
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=topdesign
# DB_USER=root
# DB_PASS=password

# Cloud Storage (for images/assets)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=topdesign-assets
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Analytics
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# FACEBOOK_PIXEL_ID=XXXXXXXXXX

# reCAPTCHA (for form spam protection)
# RECAPTCHA_SITE_KEY=your-site-key
# RECAPTCHA_SECRET_KEY=your-secret-key
